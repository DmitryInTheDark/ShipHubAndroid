<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:background="@color/main_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center|start"
            android:paddingVertical="10dp">

            <ImageButton
                android:id="@+id/ibBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                android:src="@drawable/arrow_back"
                android:backgroundTint="@color/transparent"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvClaimId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="@string/claim_number"
                style="@style/TitleTextView"
                android:textSize="16sp"
                android:layout_marginEnd="10dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:cardBackgroundColor="@color/blue"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="100dp"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:textColor="@color/blue"
                android:textSize="16sp"
                tools:text="В работе"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/timelineLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="20dp">

            <!-- ITEM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- circle + line -->
                <LinearLayout
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:background="@drawable/bg_circle"
                        tools:ignore="HardcodedText"/>

                    <View
                        android:layout_width="2dp"
                        android:layout_height="50dp"
                        android:background="#DADADA"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvClaimCreated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/claim_is_create"
                    android:textColor="#1F1F1F"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- SECOND ITEM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:text="2"
                        android:backgroundTint="@color/green"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:background="@drawable/bg_circle"
                        tools:ignore="HardcodedText" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="50dp"
                        android:background="#DADADA"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvManagerApproved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/manager_approve"
                    android:textColor="#1F1F1F"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:text="3"
                        android:backgroundTint="@color/orange"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:background="@drawable/bg_circle"
                        tools:ignore="HardcodedText" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="50dp"
                        android:background="#DADADA"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/in_work"
                    android:textColor="#1F1F1F"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:text="4"
                        android:backgroundTint="@color/turquoise"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:background="@drawable/bg_circle"
                        tools:ignore="HardcodedText" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="50dp"
                        android:background="#DADADA"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTestsCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/tests_completed"
                    android:textColor="#1F1F1F"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center|start"
                android:paddingStart="2dp"
                tools:ignore="RtlSymmetry">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="5"
                    android:backgroundTint="@color/purple"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_circle"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/tvDocumentsDelivered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/documents_delivered"
                    android:textColor="#1F1F1F"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="50dp"
            app:contentPadding="10dp"
            app:strokeColor="@color/stroke_color"
            app:strokeWidth="1dp"
            android:elevation="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TitleTextView"
                    android:text="@string/last_updates"
                    android:textSize="20sp"/>

                <LinearLayout
                    android:id="@+id/llNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/transparent"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:contentPadding="10dp"
            app:strokeColor="@color/stroke_color"
            app:strokeWidth="1dp"
            android:elevation="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TitleTextView"
                    android:text="@string/claim_details"
                    android:textSize="20sp"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="5dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            android:text="@string/equipment"
                            android:layout_marginBottom="10dp"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvEquipmentType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            tools:text="@string/equipment_type"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvEquipmentModel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            tools:text="@string/model_type"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvSerialNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            tools:text="@string/serial_number"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="5dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            android:text="@string/selected_services"
                            android:layout_marginBottom="10dp"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvServiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/NormalTextView"
                            tools:text="Анализ электромагнитной совместимости"
                            android:layout_marginBottom="10dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/photosContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPhotosTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TitleTextView"
                android:text="@string/photos"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="1">

                <ImageView
                    android:id="@+id/ivPhoto1"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/photo"/>

                <ImageView
                    android:id="@+id/ivPhoto2"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/photo"/>

                <ImageView
                    android:id="@+id/ivPhoto3"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/photo"/>

            </GridLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/bChat"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#FF6D33"
                android:text="@string/chat_with_manager"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/bDocuments"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="20dp"
                android:text="@string/go_to_documents"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="#FF6D33"
                android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>